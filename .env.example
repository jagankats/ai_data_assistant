# Database configuration (use Supabase for free cloud PostgreSQL)
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@YOUR_DB_HOST:5432/YOUR_DB_NAME

# Hugging Face configuration (free cloud LLM)
HUGGINGFACE_API_KEY=YOUR_HUGGINGFACE_API_KEY
HUGGINGFACE_MODEL=microsoft/DialoGPT-medium

# Alternative: Use Railway PostgreSQL (if not using Supabase)
DB_HOST=your_railway_db_host
DB_PORT=5432
DB_NAME=railway
DB_USER=postgres
DB_PASSWORD=your_railway_db_password
